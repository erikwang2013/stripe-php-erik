{
  "name": "erikwang2013/stripe-php-erik",
  "description": "Stripe PHP 库为 PHP 应用提供了便捷的 Stripe API 访问能力。它包含一套预定义的 API 资源类，可以动态地从 API 响应中初始化，兼容多种版本的 Stripe API。开箱即用，已适配以下框架：Laravel、Webman、Hyperf、ThinkPHP。",
  "keywords": [
    "stripe",
    "payment processing",
    "api",
    "erik",
    "erikwang2013",
    "webman",
    "laravel",
    "hyperf",
    "thinkphp"
  ],
  "homepage": "https://erik.xyz/",
  "license": "MIT",
  "authors": [
    {
      "name": "erik",
      "email": "erik@erik.xyz",
      "homepage": "https://erik.xyz",
      "role": "Developer"
    },
    {
      "name": "Stripe and contributors",
      "homepage": "https://github.com/erikwang2013/stripe-php-erik/contributors"
    }
  ],
  "require": {
    "php": ">=7.2.0",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^5.7 || ^9.0",
    "friendsofphp/php-cs-fixer": "3.94.0",
    "phpstan/phpstan": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "Erikwang2013\\Stripe\\": "lib/",
      "Erikwang2013\\Stripe\\Laravel\\": "src/Laravel/",
      "Erikwang2013\\Stripe\\Hyperf\\": "src/Hyperf/",
      "Erikwang2013\\Stripe\\ThinkPHP\\": "src/ThinkPHP/",
      "Erikwang2013\\Stripe\\Webman\\": "src/Webman/"
    },
    "files": [
      "lib/version_check.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Erikwang2013\\Stripe\\": [
        "tests/",
        "tests/Stripe/"
      ]
    }
  },
  "suggest": {
    "laravel/framework": "For Laravel integration with service provider and facade",
    "hyperf/framework": "For Hyperf coroutine-safe integration",
    "topthink/framework": "For ThinkPHP integration with service and helper",
    "workerman/webman-framework": "For webman integration with auto-config and helper"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "2.0-dev"
    },
    "laravel": {
      "providers": [
        "Erikwang2013\\Stripe\\Laravel\\StripeServiceProvider"
      ],
      "aliases": {
        "Stripe": "Erikwang2013\\Stripe\\Laravel\\Facade\\Stripe"
      }
    },
    "hyperf": {
      "config": "Erikwang2013\\Stripe\\Hyperf\\ConfigProvider"
    },
    "think": {
      "services": [
        "Erikwang2013\\Stripe\\ThinkPHP\\StripeService"
      ]
    }
  },
  "config": {
    "audit": {
      "ignore": {
        "PKSA-z3gr-8qht-p93v": "PHPUnit is only a dev dependency. Temporarily ignore PHPUnit security advisory to ensure continued support for PHP 5.6 in CI."
      }
    }
  }
}
